# Monorepo root — copy to `.env` in this same folder (repository root).
# Used by: rag-api (Python dotenv), Vite (envDir), uvicorn/pytest scripts (Node dotenv), mcp-hr-server (dotenv).

# --- OpenAI (required for ingest / ask) ---
OPENAI_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Chroma (paths relative to rag-api/ unless absolute) ---
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=handbook_chunks

# --- Repo paths (relative to monorepo root unless absolute) ---
DEFAULT_HANDBOOK_PATH=fixtures/handbook.md
EMPLOYEES_JSON_PATH=fixtures/employees.json
ALLOWED_INGEST_ROOT=.

# --- FastAPI CORS (comma-separated) ---
RAG_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Uvicorn (scripts/uvicorn-rag.cjs) ---
RAG_API_PORT=3001

# --- Vite client ---
# Dev proxy: where the Vite server forwards /api (keep VITE_API_BASE_URL unset for typical dev).
RAG_API_URL=http://127.0.0.1:3001
# Browser calls API directly (no proxy). Example: http://127.0.0.1:3001 — add UI origin to RAG_CORS_ORIGINS.
# VITE_API_BASE_URL=
